{
  "manifest_version": 3,
  "name": "Autom8ed TOTP Manager v4.5 (Vault Supported Edition)",
  "version": "4.5.0",
  "description": "Full-featured TOTP vault with auto-injection, profile management, and multi-format import support.",
  "permissions": ["storage", "scripting", "tabs", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["injector.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "64": "icon64.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    },
    "default_popup": "popup.html",
    "default_title": "Autom8ed TOTP v4.5"
  }
}
